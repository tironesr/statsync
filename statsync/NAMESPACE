# Generics
export(sync_stats)
export(report)

# S3 method registrations — THIS IS THE KEY PART
S3method(sync_stats, htest)
S3method(sync_stats, lm)
S3method(sync_stats, glm)
S3method(sync_stats, aov)
S3method(sync_stats, anova)
S3method(sync_stats, lmerMod)
S3method(sync_stats, lmerModLmerTest)
S3method(sync_stats, data.frame)
S3method(sync_stats, numeric)
S3method(sync_stats, default)
S3method(report, htest)
S3method(report, lm)
S3method(report, aov)
S3method(print, statsync_collection)
S3method("+", statsync_collection)

